{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "POSEIDON_DIR": "${HOME}/.poseidon"
  },
  "classifier": {
    "algorithm_threshold": 56,
    "native_ceiling": 55,
    "learned_boost_cap": 20,
    "pattern_decay_days": 90,
    "abandonment_detection": {
      "max_exchanges": 3,
      "min_complexity_score": 40
    }
  },
  "identity": {
    "agent_name": "Poseidon",
    "user_name": "",
    "communication_style": "direct",
    "traits": {
      "precision": 80,
      "humor": 30,
      "verbosity": 40,
      "autonomy": 60
    }
  },
  "project": {
    "active_project": "main",
    "association_priority": ["explicit", "active", "cwd", "keyword", "recent"]
  },
  "telos": {
    "files": ["MISSION.md", "GOALS.md", "PROJECTS.md"]
  },
  "learning": {
    "mode": "semi-autonomous",
    "frustration_patterns": [
      "no, that's not",
      "you forgot",
      "why did you",
      "that's wrong",
      "I said",
      "I already told you"
    ],
    "rule_deployment": "approval_required"
  },
  "security": {
    "patterns_path": "security/patterns.yaml",
    "output_scrubbing": true,
    "scrub_patterns": [
      "sk-[a-zA-Z0-9]{20,}",
      "sk-ant-[a-zA-Z0-9\\-]{20,}",
      "ghp_[a-zA-Z0-9]{36}",
      "AKIA[0-9A-Z]{16}",
      "Bearer [a-zA-Z0-9\\-._~+/]+=*"
    ]
  },
  "channels": {
    "enabled": ["terminal"],
    "rate_limit": {
      "max_messages_per_minute": 10,
      "batch_window_seconds": 5
    }
  },
  "permissions": {
    "allow": [
      "Bash", "Read", "Write", "Edit", "Glob", "Grep",
      "WebFetch", "WebSearch", "Agent", "Skill"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun ${POSEIDON_DIR}/hooks/session-start.ts"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun ${POSEIDON_DIR}/hooks/pre-prompt.ts"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${POSEIDON_DIR}/hooks/pre-tool.ts"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${POSEIDON_DIR}/hooks/pre-tool.ts"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${POSEIDON_DIR}/hooks/pre-tool.ts"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${POSEIDON_DIR}/hooks/pre-tool.ts"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${POSEIDON_DIR}/hooks/error-capture.ts"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${POSEIDON_DIR}/hooks/error-capture.ts"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${POSEIDON_DIR}/hooks/error-capture.ts"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${POSEIDON_DIR}/hooks/error-capture.ts"
          }
        ]
      },
      {
        "matcher": "WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${POSEIDON_DIR}/hooks/error-capture.ts"
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "bun ${POSEIDON_DIR}/hooks/error-capture.ts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun ${POSEIDON_DIR}/hooks/post-response.ts"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun ${POSEIDON_DIR}/hooks/session-end.ts"
          }
        ]
      }
    ]
  }
}
